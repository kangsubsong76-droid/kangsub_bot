# === KangSub Bot 환경변수 ===
# 이 파일을 .env로 복사하고 실제 값을 입력하세요
# cp .env.example .env

# 텔레그램
TELEGRAM_TOKEN=your_telegram_bot_token
TELEGRAM_CHAT_ID=your_chat_id

# Notion
NOTION_TOKEN=your_notion_token
NOTION_DB_TRADES=your_trades_db_id
NOTION_DB_PORTFOLIO=your_portfolio_db_id
NOTION_DB_SIGNALS=your_signals_db_id
NOTION_DB_NEWS=your_news_db_id

# DART
DART_API_KEY=your_dart_api_key

# 키움증권 REST API (openapi.kiwoom.com)
KIWOOM_ACCOUNT=6594-7112
KIWOOM_APP_KEY=your_app_key
KIWOOM_SECRET_KEY=your_secret_key
KIWOOM_MOCK=true
